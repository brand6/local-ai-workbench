{
  "name": "github-repo-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server/electron/main.js",
  "scripts": {
    "dev": "tsx src/server/index.ts --dev",
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.electron.json && vite build",
    "electron": "npm run build && electron .",
    "pack": "npm run build && node scripts/electron-builder.mjs --dir",
    "dist": "npm run build && node scripts/electron-builder.mjs",
    "dist:portable": "npm run build && node scripts/electron-builder.mjs --win portable",
    "start": "node dist/server/server/index.js",
    "check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  },
  "build": {
    "appId": "local.github-repo-manager",
    "productName": "GitHub Repo Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/server/**/*",
      "dist/client/**/*",
      "builtin-skills/**/*",
      "builtin-mcps/**/*",
      "skills-lock.json",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
